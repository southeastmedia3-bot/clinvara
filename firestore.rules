rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
          )
          || (
            exists(/databases/$(database)/documents/customers/$(request.auth.uid))
            && get(/databases/$(database)/documents/customers/$(request.auth.uid)).data.role == "admin"
          )
        );
    }

    function doesNotEditRole() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]);
    }

    function doesNotCreateRole() {
      return !request.resource.data.keys().hasAny(["role"]);
    }

    function ownsOrder(orderId) {
      return signedIn()
        && exists(/databases/$(database)/documents/orders/$(orderId))
        && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid
          || get(/databases/$(database)/documents/orders/$(orderId)).data.uid == request.auth.uid
          || get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid
        );
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && doesNotCreateRole();
      allow read: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && doesNotEditRole()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /customers/{userId} {
      allow create: if isOwner(userId) && doesNotCreateRole();
      allow read: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && doesNotEditRole()) || isAdmin();
      allow delete: if isAdmin();

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /cart/{itemId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /wishlist/{itemId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /skinAnalyses/{analysisId} {
        allow read, create, update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if signedIn()
                    && (
                      request.resource.data.userId == request.auth.uid
                      || request.resource.data.uid == request.auth.uid
                      || isAdmin()
                    );
      allow read: if isAdmin()
                  || (
                    signedIn()
                    && (
                      resource.data.userId == request.auth.uid
                      || resource.data.uid == request.auth.uid
                    )
                  );
      allow update, delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.status == "approved" || isAdmin();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /returns/{returnId} {
      allow create: if signedIn()
                    && request.resource.data.customerId == request.auth.uid
                    && request.resource.data.status == "requested"
                    && ownsOrder(request.resource.data.orderId);
      allow read: if isAdmin()
                  || (signedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /externalChannels/{channelId} {
      allow read, write: if isAdmin();
    }

    match /externalChannelProducts/{recordId} {
      allow read, write: if isAdmin();
    }

    match /externalChannelInventory/{recordId} {
      allow read, write: if isAdmin();
    }

    match /externalChannelOrders/{recordId} {
      allow read, write: if isAdmin();
    }

    match /externalChannelRevenue/{recordId} {
      allow read, write: if isAdmin();
    }

    match /externalChannelReturns/{recordId} {
      allow read, write: if isAdmin();
    }

    match /externalChannelSettlements/{recordId} {
      allow read, write: if isAdmin();
    }

    match /analyticsCache/{cacheId} {
      allow read, write, delete: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }
  }
}
