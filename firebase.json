{
  "apphosting": [
    {
      "backendId": "clinvara-backend",
      "rootDir": "frontend",
      "ignore": [
        "node_modules",
        ".git",
        ".next",
        ".env",
        ".env.*",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "legacy-root-app"
      ]
    }
  ],
  "functions": [
    {
      "source": "backend",
      "codebase": "backend"
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}